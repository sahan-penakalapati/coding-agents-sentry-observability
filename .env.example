# Sentry export is optional. Leave SENTRY_DSN empty for local-only mode.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=agent-vm-usage
SENTRY_PROJECT_ID=

# Local stores and telemetry sources.
AGENT_VM_MEMORY_DB=~/.agent-vm-observability/memory.db
AGENT_VM_CODEX_LOGS_DB=~/.codex/logs_2.sqlite
AGENT_VM_CODEX_STATE_DB=~/.codex/state_5.sqlite
AGENT_VM_CLAUDE_GLOB=~/.claude/projects/**/*.jsonl
AGENT_VM_PI_SUGGESTER_GLOB=~/.pi/suggester
AGENT_VM_PI_SESSION_GLOB=~/.pi/agent/sessions/**/*.jsonl

# Privacy and runtime behavior.
AGENT_SENTRY_INCLUDE_TEXT=0
AGENT_VM_RECORD_MEMORY=1
AGENT_VM_MAX_BATCH=250
AGENT_VM_POLL_SECONDS=15
SENTRY_TRACES_SAMPLE_RATE=1.0
