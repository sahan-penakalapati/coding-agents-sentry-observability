# coding-agents-sentry-observability configuration example
# Copy to ~/.config/agent-vm-observability/env and chmod 600 it.

# Optional: export traces to Sentry. Leave unset for local-only mode.
# SENTRY_DSN=
# Required only for `agent-vm sentry apply-dashboards`.
# SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=agent-vm-usage
# SENTRY_PROJECT_ID=

# Privacy: keep raw message/tool text out of Sentry and the local DB by default.
AGENT_VM_INCLUDE_TEXT=0
AGENT_VM_RECORD_MEMORY=1

# Runtime behavior.
AGENT_VM_POLL_SECONDS=15
AGENT_VM_MAX_BATCH=250

# Local state. Tilde expansion is supported for path-valued settings.
AGENT_VM_MEMORY_DB=~/.agent-vm-observability/memory.db
AGENT_VM_STATE=~/.local/state/agent-vm-observability/state.json

# Source locations. Defaults usually work for Claude Code and Codex.
# AGENT_VM_CODEX_LOGS_DB=/Users/you/.codex/logs_2.sqlite
# AGENT_VM_CODEX_STATE_DB=/Users/you/.codex/state_5.sqlite
# AGENT_VM_CLAUDE_GLOB=/Users/you/.claude/projects/**/*.jsonl
# AGENT_VM_CLAUDE_MEM_DB=~/.claude-mem/claude-mem.db

# Optional pricing override. JSON list of pricing rules; see src/agent_vm_observability/pricing.py.
# AGENT_VM_MODEL_PRICING_JSON=[]
# AGENT_VM_MODEL_PRICING_FILE=/path/to/pricing.json
